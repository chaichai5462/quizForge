rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: any auth user can read, only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Quizzes: any auth user can read/write
    match /quizzes/{quizId} {
      allow read, write: if request.auth != null;
    }

    // Attempts: any auth can read, only owner can create, no update/delete
    match /attempts/{attemptId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }

    // Connections: student creates own, both parties read, only teacher updates
    match /connections/{connectionId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.teacherId
      );
      allow update: if request.auth != null && request.auth.uid == resource.data.teacherId;
    }

    // Live sessions: any auth user can read/write
    match /live_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
